{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; p=int(os.environ.get('PORT',8080)); socketserver.TCPServer(('',p),http.server.SimpleHTTPRequestHandler).serve_forever()"],
      "port": 8080,
      "autoPort": true
    }
  ]
}
